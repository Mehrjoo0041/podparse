{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://podparse.onrender.com/api/:path*" },
    { "source": "/media/:path*", "destination": "https://podparse.onrender.com/media/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
